 "font_size": 14,
 "html": "\n<div class=\"receipt\">\n  <style>\n    .receipt { font-family: Arial, sans-serif; font-size: 10.5pt; color: #1a1a1a; }\n\n    .rc-header { width: 100%; border-collapse: collapse; border-bottom: 2.5px solid #004d40; padding-bottom: 6px; margin-bottom: 6px; }\n    .rc-header td { border: none; vertical-align: middle; padding: 0; }\n    .rc-header .logo-cell { width: 80px; }\n    .rc-header .logo { max-height: 70px; max-width: 70px; }\n    .rc-header .school-block { text-align: center; }\n    .rc-header h1 { color: #004d40; margin: 0 0 1px 0; font-size: 15pt; letter-spacing: 0.4px; }\n    .rc-header .motto { font-style: italic; color: #555; margin: 0 0 2px 0; font-size: 8.5pt; }\n    .rc-header .contact { font-size: 7.8pt; color: #555; margin: 0; }\n    .rc-header .badge-cell { width: 100px; text-align: right; vertical-align: top; }\n    .rc-official-badge {\n      display: inline-block; border: 1px solid #004d40; color: #004d40;\n      font-size: 6.6pt; font-weight: bold; letter-spacing: 0.6px; text-transform: uppercase;\n      padding: 2.5px 6px; border-radius: 3px; white-space: nowrap;\n    }\n\n    .rc-title-bar { text-align: center; background: #004d40; color: #fff; font-weight: bold; padding: 5px 0; margin-bottom: 4px; letter-spacing: 0.5px; font-size: 12pt; }\n    .rc-authenticity { text-align: center; font-size: 7.5pt; color: #004d40; background: #e0f2f1; border: 1px solid #b2dfdb; padding: 3px 6px; margin-bottom: 10px; border-radius: 3px; }\n\n    .rc-details table { width: 100%; margin-bottom: 12px; }\n    .rc-details td { padding: 2px 8px 2px 0; font-size: 10pt; }\n\n    .rc-amount { width: 100%; border-collapse: collapse; margin-bottom: 10px; }\n    .rc-amount th, .rc-amount td { border: 1px solid #cfd8d7; padding: 8px 10px; text-align: left; }\n    .rc-amount th { background: #e0f2f1; color: #004d40; font-size: 8pt; text-transform: uppercase; letter-spacing: 0.2px; }\n    .rc-amount td.num { text-align: right; font-weight: bold; font-size: 12pt; color: #004d40; }\n\n    .rc-balance-box { border: 1px solid #cfd8d7; border-radius: 4px; padding: 6px 12px; margin-bottom: 14px; }\n    .rc-balance-box table { width: 100%; border-collapse: collapse; font-size: 9.5pt; }\n    .rc-balance-box td { border: none; padding: 2px 0; }\n    .rc-balance-box .label { color: #555; }\n    .rc-balance-box .value { font-weight: bold; text-align: right; }\n    .rc-balance-box .final .value, .rc-balance-box .final .label { color: #004d40; }\n\n    .rc-thanks { text-align: center; font-style: italic; color: #444; margin-bottom: 24px; }\n\n    .rc-signatures { width: 100%; border-collapse: collapse; margin-top: 10px; }\n    .rc-signatures td { border: none; padding: 0; width: 45%; }\n    .rc-signatures td.gap { width: 10%; }\n    .rc-signatures .sig { border-top: 1px solid #333; text-align: center; padding-top: 2px; font-size: 8.5pt; }\n\n    .rc-footer { font-size: 8pt; color: #666; margin-top: 16px; border-top: 1px solid #cfd8d7; padding-top: 5px; }\n  </style>\n\n  {% set school_name = frappe.db.get_single_value(\"School Settings\", \"school_name\") %}\n  {% set school_motto = frappe.db.get_single_value(\"School Settings\", \"motto\") %}\n  {% set school_address = frappe.db.get_single_value(\"School Settings\", \"address\") %}\n  {% set school_phone = frappe.db.get_single_value(\"School Settings\", \"phone\") %}\n  {% set school_email = frappe.db.get_single_value(\"School Settings\", \"email\") %}\n  {% set school_logo = school_logo_data_uri() %}\n  {% set ctx = get_receipt_context(doc.name) %}\n\n  <table class=\"rc-header\">\n    <tr>\n      <td class=\"logo-cell\">{% if school_logo %}<img src=\"{{ school_logo }}\" class=\"logo\">{% endif %}</td>\n      <td class=\"school-block\">\n        <h1>{{ school_name or \"School Name Not Set\" }}</h1>\n        {% if school_motto %}<p class=\"motto\">{{ school_motto }}</p>{% endif %}\n        <p class=\"contact\">\n          {{ school_address.replace(\"\\n\", \", \").replace(\", ,\", \",\") if school_address else \"\" }}\n          {% if school_phone %} &nbsp;|&nbsp; Tel: {{ school_phone }}{% endif %}\n          {% if school_email %} &nbsp;|&nbsp; {{ school_email }}{% endif %}\n        </p>\n      </td>\n      <td class=\"badge-cell\"><span class=\"rc-official-badge\">Official Receipt</span></td>\n    </tr>\n  </table>\n\n  <div class=\"rc-title-bar\">PAYMENT RECEIPT</div>\n  <div class=\"rc-authenticity\">\n    This receipt confirms a payment received by {{ school_name or \"the school\" }}. Reference number below matches this student's official fee ledger.\n  </div>\n\n  <div class=\"rc-details\">\n    <table>\n      <tr>\n        <td><strong>Receipt No:</strong> {{ doc.name }}</td>\n        <td><strong>Date:</strong> {{ frappe.utils.format_datetime(doc.posting_datetime, \"dd MMM yyyy, HH:mm\") }}</td>\n      </tr>\n      <tr>\n        <td><strong>Student:</strong> {{ doc.student_name }}</td>\n        <td><strong>Class:</strong> {{ ctx.student_group }}</td>\n      </tr>\n    </table>\n  </div>\n\n  <table class=\"rc-amount\">\n    <thead>\n      <tr><th>Description</th><th style=\"text-align:right;\">Amount Received</th></tr>\n    </thead>\n    <tbody>\n      <tr>\n        <td>{{ doc.description }}</td>\n        <td class=\"num\">${{ \"%.2f\"|format(doc.credit) }}</td>\n      </tr>\n    </tbody>\n  </table>\n\n  {% if ctx.fee %}\n  <div class=\"rc-balance-box\">\n    <table>\n      <tr><td class=\"label\">Term:</td><td class=\"value\">{{ ctx.fee.academic_term }}</td></tr>\n      <tr><td class=\"label\">Total Billed:</td><td class=\"value\">${{ \"%.2f\"|format(ctx.fee.amount) }}</td></tr>\n      <tr><td class=\"label\">Total Paid to Date:</td><td class=\"value\">${{ \"%.2f\"|format(ctx.fee.amount_paid) }}</td></tr>\n      <tr class=\"final\"><td class=\"label\">Balance Remaining:</td><td class=\"value\">${{ \"%.2f\"|format(ctx.fee.balance) }}</td></tr>\n    </table>\n  </div>\n  {% endif %}\n\n  <div class=\"rc-thanks\">Received with thanks.</div>\n\n  <table class=\"rc-signatures\">\n    <tr>\n      <td><div class=\"sig\">Bursar Signature</div></td>\n      <td class=\"gap\"></td>\n      <td><div class=\"sig\">Parent / Guardian Copy</div></td>\n    </tr>\n  </table>\n\n  <div class=\"rc-footer\">\n    Generated {{ frappe.utils.now_datetime().strftime(\"%Y-%m-%d %H:%M\") }}\n    {% if school_phone %} | {{ school_phone }}{% endif %}\n    {% if school_email %} | {{ school_email }}{% endif %}\n  </div>\n</div>\n",
 "idx": 0,
 "line_breaks": 0,
 "margin_bottom": 12.0,
