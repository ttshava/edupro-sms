 "font_size": 14,
 "html": "\n<div class=\"fee-statement\">\n  <style>\n    .fee-statement { font-family: Arial, sans-serif; font-size: 11pt; color: #1a1a1a; }\n\n    .fs-header { width: 100%; border-collapse: collapse; border-bottom: 2.5px solid #004d40; padding-bottom: 6px; margin-bottom: 6px; }\n    .fs-header td { border: none; vertical-align: middle; padding: 0; }\n    .fs-header .logo-cell { width: 80px; }\n    .fs-header .logo { max-height: 70px; max-width: 70px; }\n    .fs-header .school-block { text-align: center; }\n    .fs-header h1 { color: #004d40; margin: 0 0 1px 0; font-size: 16pt; letter-spacing: 0.4px; }\n    .fs-header .motto { font-style: italic; color: #555; margin: 0 0 2px 0; }\n    .fs-header .contact { font-size: 8.5pt; color: #555; margin: 0; }\n    .fs-header .badge-cell { width: 100px; text-align: right; vertical-align: top; }\n    .fs-official-badge {\n      display: inline-block; border: 1px solid #004d40; color: #004d40;\n      font-size: 6.6pt; font-weight: bold; letter-spacing: 0.6px; text-transform: uppercase;\n      padding: 2.5px 6px; border-radius: 3px; white-space: nowrap;\n    }\n\n    .fs-title-bar { text-align: center; background: #004d40; color: #fff; font-weight: bold; padding: 5px 0; margin-bottom: 4px; letter-spacing: 0.5px; }\n    .fs-authenticity { text-align: center; font-size: 8pt; color: #004d40; background: #e0f2f1; border: 1px solid #b2dfdb; padding: 4px 6px; margin-bottom: 12px; border-radius: 3px; }\n    .fs-details table { width: 100%; margin-bottom: 12px; }\n    .fs-details td { padding: 2px 8px 2px 0; }\n    .fs-summary { width: 100%; margin-bottom: 14px; }\n    .fs-summary .box { border: 1px solid #cfd8d7; border-radius: 4px; padding: 8px 14px; text-align: center; display: inline-block; }\n    .fs-summary .box .v { font-size: 14pt; font-weight: bold; color: #004d40; }\n    .fs-summary .box .l { font-size: 8pt; color: #666; text-transform: uppercase; }\n    .fs-table { width: 100%; border-collapse: collapse; margin-bottom: 4px; font-size: 9.5pt; }\n    .fs-table th, .fs-table td { border: 1px solid #cfd8d7; padding: 5px 7px; text-align: left; }\n    .fs-table th { background: #e0f2f1; color: #004d40; }\n    .fs-table td.num { text-align: right; }\n    .fs-table tfoot td { font-weight: bold; background: #f2f7f6; }\n    .fs-note { font-size: 8pt; color: #888; margin-bottom: 12px; }\n    .fs-footer { font-size: 9pt; color: #666; margin-top: 20px; border-top: 1px solid #cfd8d7; padding-top: 6px; }\n  </style>\n\n  {% set school_name = frappe.db.get_single_value(\"School Settings\", \"school_name\") %}\n  {% set school_motto = frappe.db.get_single_value(\"School Settings\", \"motto\") %}\n  {% set school_address = frappe.db.get_single_value(\"School Settings\", \"address\") %}\n  {% set school_phone = frappe.db.get_single_value(\"School Settings\", \"phone\") %}\n  {% set school_email = frappe.db.get_single_value(\"School Settings\", \"email\") %}\n  {% set school_logo = school_logo_data_uri() %}\n  {% set statement = get_student_fee_statement(doc.name) %}\n  {% set ledger = get_student_ledger(doc.name) %}\n\n  <table class=\"fs-header\">\n    <tr>\n      <td class=\"logo-cell\">{% if school_logo %}<img src=\"{{ school_logo }}\" class=\"logo\">{% endif %}</td>\n      <td class=\"school-block\">\n        <h1>{{ school_name or \"School Name Not Set\" }}</h1>\n        {% if school_motto %}<p class=\"motto\">{{ school_motto }}</p>{% endif %}\n        <p class=\"contact\">\n          {{ school_address.replace(\"\\n\", \", \").replace(\", ,\", \",\") if school_address else \"\" }}\n          {% if school_phone %} &nbsp;|&nbsp; Tel: {{ school_phone }}{% endif %}\n          {% if school_email %} &nbsp;|&nbsp; {{ school_email }}{% endif %}\n        </p>\n      </td>\n      <td class=\"badge-cell\"><span class=\"fs-official-badge\">Official Document</span></td>\n    </tr>\n  </table>\n\n  <div class=\"fs-title-bar\">FEE STATEMENT &mdash; {{ statement.academic_year or \"-\" }}</div>\n  <div class=\"fs-authenticity\">\n    This is an official financial document issued by {{ school_name or \"the school\" }}. Every transaction below is timestamped and recorded at the time it occurred.\n  </div>\n\n  <div class=\"fs-details\">\n    <table>\n      <tr>\n        <td><strong>Student:</strong> {{ doc.student_name }}</td>\n        <td><strong>Boarding Type:</strong> {{ statement.boarding_type }}</td>\n      </tr>\n    </table>\n  </div>\n\n  <div class=\"fs-summary\">\n    <div class=\"box\"><div class=\"v\">${{ \"%.0f\"|format(ledger.closing_balance) }}</div><div class=\"l\">Closing Balance</div></div>\n  </div>\n\n  <table class=\"fs-table\">\n    <thead>\n      <tr><th>Date &amp; Time</th><th>Description</th><th>Debit</th><th>Credit</th><th>Balance</th></tr>\n    </thead>\n    <tbody>\n      {% for row in ledger.entries %}\n      <tr>\n        <td>{{ frappe.utils.format_datetime(row.posting_datetime, \"dd MMM yyyy HH:mm\") }}</td>\n        <td>{{ row.description }}</td>\n        <td class=\"num\">{{ \"$%.2f\"|format(row.debit) if row.debit else \"-\" }}</td>\n        <td class=\"num\">{{ \"$%.2f\"|format(row.credit) if row.credit else \"-\" }}</td>\n        <td class=\"num\">${{ \"%.2f\"|format(row.balance) }}</td>\n      </tr>\n      {% else %}\n      <tr><td colspan=\"5\" style=\"text-align:center; color:#888; font-style:italic;\">No transactions recorded yet.</td></tr>\n      {% endfor %}\n    </tbody>\n    <tfoot>\n      <tr><td colspan=\"4\">CLOSING BALANCE</td><td class=\"num\">${{ \"%.2f\"|format(ledger.closing_balance) }}</td></tr>\n    </tfoot>\n  </table>\n  <div class=\"fs-note\">Debit = amount billed. Credit = amount paid. Balance is a running total after each transaction.</div>\n\n  <div class=\"fs-footer\">\n    Generated {{ frappe.utils.now_datetime().strftime(\"%Y-%m-%d %H:%M\") }}\n    {% if school_phone %} | {{ school_phone }}{% endif %}\n    {% if school_email %} | {{ school_email }}{% endif %}\n  </div>\n</div>\n",
