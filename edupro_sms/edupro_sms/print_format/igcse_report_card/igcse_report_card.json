 "doctype": "Print Format",
 "font_size": 14,
 "html": "\n<div class=\"report-card\">\n  <style>\n    .report-card { font-family: Arial, sans-serif; font-size: 9pt; color: #1a1a1a; position: relative; }\n\n    .rc-watermark {\n      position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);\n      width: 430px; max-width: 430px; z-index: 0; pointer-events: none;\n    }\n    .rc-content { position: relative; z-index: 1; }\n\n    .rc-header { width: 100%; border-collapse: collapse; border-bottom: 2.5px solid #004d40; padding-bottom: 4px; margin-bottom: 3px; }\n    .rc-header td { border: none; vertical-align: middle; padding: 0; }\n    .rc-header .logo-cell { width: 90px; }\n    .rc-header .logo { max-height: 82px; max-width: 82px; }\n    .rc-header .school-block { text-align: center; }\n    .rc-header h1 { color: #004d40; margin: 0 0 1px 0; font-size: 16pt; letter-spacing: 0.4px; }\n    .rc-header .motto { font-style: italic; color: #555; margin: 0 0 2px 0; font-size: 8.3pt; }\n    .rc-header .contact { font-size: 7.5pt; color: #555; margin: 0; }\n    .rc-header .badge-cell { width: 110px; text-align: right; vertical-align: top; }\n    .rc-official-badge {\n      display: inline-block; border: 1px solid #004d40; color: #004d40;\n      font-size: 6.6pt; font-weight: bold; letter-spacing: 0.6px; text-transform: uppercase;\n      padding: 2.5px 6px; border-radius: 3px; white-space: nowrap;\n    }\n\n    .rc-title-bar { text-align: center; background: #004d40; color: #fff; font-weight: bold; padding: 3px 0; margin-bottom: 2px; letter-spacing: 0.5px; font-size: 10pt; }\n    .rc-authenticity { text-align: center; font-size: 6.8pt; color: #004d40; background: #e0f2f1; border: 1px solid #b2dfdb; padding: 2px 6px; margin-bottom: 4px; border-radius: 3px; }\n\n    .rc-details table { width: 100%; margin-bottom: 3px; }\n    .rc-details td { padding: 0.5px 8px 0.5px 0; font-size: 9pt; }\n\n    .rc-results { width: 100%; border-collapse: collapse; margin-bottom: 4px; font-size: 7.8pt; table-layout: fixed; }\n    .rc-results th, .rc-results td { border: 1px solid #cfd8d7; padding: 1.5px 5px; text-align: left; }\n    .rc-results th { background: #e0f2f1; color: #004d40; font-size: 7.2pt; text-transform: uppercase; letter-spacing: 0.2px; padding: 2px 5px; }\n    .rc-results th:nth-child(1), .rc-results td:nth-child(1) { width: 24%; }\n    .rc-results th:nth-child(2), .rc-results td:nth-child(2) { width: 12%; }\n    .rc-results th:nth-child(3), .rc-results td:nth-child(3) { width: 12%; }\n    .rc-results th:nth-child(4), .rc-results td:nth-child(4) { width: 52%; }\n    .rc-results td.rc-num { white-space: nowrap; }\n    .rc-results td:nth-child(4) { font-size: 7.1pt; line-height: 1.15; word-break: break-word; }\n    .rc-results tfoot td { font-weight: bold; background: #f2f7f6; font-size: 7.8pt; }\n\n    .rc-comment { border: 1px solid #cfd8d7; padding: 2.5px 7px; margin-bottom: 3px; border-radius: 3px; }\n    .rc-comment .label {\n      display: inline-block; font-weight: bold; color: #fff; background: #004d40;\n      font-size: 6.8pt; letter-spacing: 0.3px; text-transform: uppercase; padding: 1px 6px;\n      border-radius: 2px; margin-bottom: 2px;\n    }\n    .rc-comment .body { font-size: 7.9pt; line-height: 1.15; }\n\n    .rc-term-dates { text-align: right; font-size: 7.2pt; color: #444; margin: 1px 0 3px 0; }\n\n    .rc-signatures { width: 100%; border-collapse: collapse; margin-top: 3px; }\n    .rc-signatures td { border: none; padding: 0; width: 45%; }\n    .rc-signatures td.gap { width: 10%; }\n    .rc-signatures .sig { border-top: 1px solid #333; text-align: center; padding-top: 2px; font-size: 7.6pt; }\n\n    .rc-footer-wrap { width: 100%; border-collapse: collapse; margin-top: 2px; border-top: 1px solid #cfd8d7; }\n    .rc-footer-wrap td { padding: 1px 0; vertical-align: top; border: none; }\n    .rc-footer { font-size: 7pt; color: #666; line-height: 1.35; }\n    .rc-qr { text-align: right; }\n    .rc-qr img { width: 40px; height: 40px; }\n    .rc-qr .caption { font-size: 5.8pt; color: #888; margin-top: 1px; }\n  </style>\n\n  {% set school_name = frappe.db.get_single_value(\"School Settings\", \"school_name\") %}\n  {% set school_motto = frappe.db.get_single_value(\"School Settings\", \"motto\") %}\n  {% set school_address = frappe.db.get_single_value(\"School Settings\", \"address\") %}\n  {% set school_phone = frappe.db.get_single_value(\"School Settings\", \"phone\") %}\n  {% set school_email = frappe.db.get_single_value(\"School Settings\", \"email\") %}\n  {% set school_logo = school_logo_data_uri() %}\n\n  {% set watermark_uri = report_card_watermark_data_uri() %}\n  {% if watermark_uri %}<img src=\"{{ watermark_uri }}\" class=\"rc-watermark\">{% endif %}\n\n  <div class=\"rc-content\">\n\n  <table class=\"rc-header\">\n    <tr>\n      <td class=\"logo-cell\">{% if school_logo %}<img src=\"{{ school_logo }}\" class=\"logo\">{% endif %}</td>\n      <td class=\"school-block\">\n        <h1>{{ school_name or \"School Name Not Set\" }}</h1>\n        {% if school_motto %}<p class=\"motto\">{{ school_motto }}</p>{% endif %}\n        <p class=\"contact\">\n          {{ school_address.replace(\"\\n\", \", \").replace(\", ,\", \",\") if school_address else \"\" }}\n          {% if school_phone %} &nbsp;|&nbsp; Tel: {{ school_phone }}{% endif %}\n          {% if school_email %} &nbsp;|&nbsp; {{ school_email }}{% endif %}\n        </p>\n      </td>\n      <td class=\"badge-cell\"><span class=\"rc-official-badge\">Official Document</span></td>\n    </tr>\n  </table>\n\n  <div class=\"rc-title-bar\">TERM REPORT CARD &mdash; {{ doc.academic_term }}</div>\n  <div class=\"rc-authenticity\">\n    This is an official academic document issued by {{ school_name or \"the school\" }}. Its authenticity can be verified using the QR code / verification code printed at the foot of this report.\n  </div>\n\n  <div class=\"rc-details\">\n    <table>\n      <tr>\n        <td><strong>Student:</strong> {{ doc.student_name }}</td>\n        <td><strong>Class:</strong> {{ doc.student_group }}</td>\n      </tr>\n      <tr>\n        <td><strong>Term:</strong> {{ doc.academic_term }}</td>\n        <td><strong>Academic Year:</strong> {{ doc.academic_year }}</td>\n      </tr>\n    </table>\n  </div>\n\n  <table class=\"rc-results\">\n    <thead>\n      <tr>\n        <th>Subject</th>\n        <th>Term</th>\n        <th>Exam</th>\n        <th>Comment</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for row in doc.assessment_results %}\n      <tr>\n        <td>{{ row.reporting_subject or row.course }}</td>\n        <td class=\"rc-num\">{{ \"%.0f\"|format(row.term_mark) ~ \"% (\" ~ row.term_grade ~ \")\" if row.term_mark is not none and row.term_grade != \"NONE\" else \"-\" }}</td>\n        <td class=\"rc-num\">{{ \"%.0f\"|format(row.exam_mark) ~ \"% (\" ~ row.exam_grade ~ \")\" if row.exam_mark is not none and row.exam_grade != \"NONE\" else \"-\" }}</td>\n        <td>{{ row.comment or \"\" }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n    <tfoot>\n      <tr>\n        <td>TOTAL: {{ doc.total_score }} / {{ doc.maximum_score }}</td>\n        <td colspan=\"2\">AVERAGE: {{ \"%.0f\"|format(doc.average_percentage) }}% &nbsp;&middot;&nbsp; GRADE: {{ doc.overall_grade }}</td>\n        <td>POSITION: {{ doc.position }} / {{ doc.number_of_students }}</td>\n      </tr>\n    </tfoot>\n  </table>\n\n  <div class=\"rc-comment\">\n    <div class=\"label\">Class Teacher Comment</div>\n    <div class=\"body\">{{ doc.class_teacher_comment or \"\" }}</div>\n  </div>\n\n  {% if doc.conduct_remark %}\n  <div class=\"rc-comment\">\n    <div class=\"label\">Conduct</div>\n    <div class=\"body\">{{ doc.conduct_remark }}</div>\n  </div>\n  {% endif %}\n\n  <div class=\"rc-comment\">\n    <div class=\"label\">Headmaster Comment</div>\n    <div class=\"body\">{{ doc.headmaster_comment or \"\" }}</div>\n  </div>\n\n  {% set next_term_start = get_next_term_start(doc.academic_term) %}\n  {% if next_term_start %}\n  <div class=\"rc-term-dates\"><strong>Next Term Begins:</strong> {{ frappe.utils.formatdate(next_term_start, \"dd MMMM yyyy\") }}</div>\n  {% endif %}\n\n  <table class=\"rc-signatures\">\n    <tr>\n      <td><div class=\"sig\">Class Teacher Signature</div></td>\n      <td class=\"gap\"></td>\n      <td><div class=\"sig\">Headmaster Signature</div></td>\n    </tr>\n  </table>\n\n  {% set qr_data_uri = report_card_verification_qr_data_uri(doc.verification_code) %}\n  <table class=\"rc-footer-wrap\">\n    <tr>\n      <td class=\"rc-footer\">\n        Generated {{ frappe.utils.now_datetime().strftime(\"%Y-%m-%d\") }}\n        {% if school_phone %} | {{ school_phone }}{% endif %}\n        {% if school_email %} | {{ school_email }}{% endif %}\n        <br>Verification Code: {{ doc.verification_code or \"-\" }}\n      </td>\n      {% if qr_data_uri %}\n      <td class=\"rc-qr\">\n        <img src=\"{{ qr_data_uri }}\" width=\"40\" height=\"40\">\n        <div class=\"caption\">Scan to verify</div>\n      </td>\n      {% endif %}\n    </tr>\n  </table>\n\n  </div>\n</div>\n",
