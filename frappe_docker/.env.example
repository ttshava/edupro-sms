# Edupro SMS local dev environment (Frappe v15 + ERPNext v15 + Education v15, Python 3.11)
# Copy this to .env and fill in real values -- .env itself stays gitignored
# (it holds real secrets; this file is the redacted template).

# Point compose at the custom image we built (images/custom/Containerfile),
# never try to pull frappe/erpnext from Docker Hub instead.
CUSTOM_IMAGE=edupro-sms
CUSTOM_TAG=v15
PULL_POLICY=never

# Set real values before `docker compose up` -- these seed the MariaDB
# root password and the Administrator account on first site creation.
# Changing DB_PASSWORD after the site/DB already exist does nothing on its
# own; it only takes effect on `bench new-site`.
DB_PASSWORD=change-me
SITE_NAME=edupro.localhost
ADMIN_PASSWORD=change-me

# Always resolve to our one site regardless of what Host header the browser
# sends, so http://localhost:8080 works without editing the hosts file.
FRAPPE_SITE_NAME_HEADER=edupro.localhost

HTTP_PUBLISH_PORT=8080
